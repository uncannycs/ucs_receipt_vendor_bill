<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="vpicktree_inherit_ucs_receipt_vendor_bill" model="ir.ui.view">
        <field name="name">stock.picking.tree.inherit.ucs_receipt_vendor_bill</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='origin']" position="after">
                <field name="vendor_bill_ids" widget="many2many_tags" invisible="picking_type_code != 'incoming'" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_picking_form_inherit_ucs_receipt_vendor_bill" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.ucs_receipt_vendor_bill</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='origin']" position="after">
                <field name="vendor_bill_ids" widget="many2many_tags" invisible="picking_type_code != 'incoming'" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
